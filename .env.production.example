# Asistant — Lightsail production env template
# Copy to .env.production and fill in real values. Never commit .env.production.
# chmod 600 .env.production after creating.

# === Required ===
GOOGLE_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=hybrid-rag
VECTOR_STORE_BACKEND=pinecone

# === Optional dual-LLM ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Optional Qdrant (only if VECTOR_STORE_BACKEND=qdrant) ===
# QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=constructioniq

# === Optional OCR ===
OCR_MODE=auto
OCR_LANG=eng
OCR_DPI=200
OCR_MAX_PAGES=500

# === Optional safety / cost limits ===
MAX_LLM_CALLS=4
LLM_TIMEOUT=30
LLM_MAX_RETRIES=1
CACHE_TTL=3600

# Global LLM budget cap (USD) shared across conversations.
# When the cumulative cost reaches this value, /api/chat returns HTTP 402.
ASISTANT_USAGE_LIMIT_USD=100
