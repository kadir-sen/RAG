{
  "schema_id": "equipment_log",
  "name": "Equipment Log",
  "description": "Daily equipment/machinery deployment tracking across construction blocks and floors with hourly utilization",
  "columns": [
    {
      "name": "Date",
      "dtype": "date",
      "required": true,
      "description": "Work date",
      "aliases": ["date", "work_date"]
    },
    {
      "name": "Block",
      "dtype": "string",
      "required": true,
      "description": "Construction block identifier",
      "aliases": ["block", "building"]
    },
    {
      "name": "Floor",
      "dtype": "string",
      "required": true,
      "description": "Floor number or reference",
      "aliases": ["floor", "level", "storey"]
    },
    {
      "name": "Machinery Name",
      "dtype": "string",
      "required": true,
      "description": "Equipment or machinery type name",
      "aliases": ["machinery", "equipment", "machine", "machinery_name"]
    },
    {
      "name": "Estimated Machinery Hours",
      "dtype": "float",
      "required": true,
      "description": "Estimated operating hours for the machinery",
      "aliases": ["hours", "machinery hours", "estimated_hours", "operating_hours"]
    }
  ]
}
